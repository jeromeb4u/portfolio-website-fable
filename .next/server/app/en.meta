{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(frontend)/layout,_N_T_/(frontend)/[locale]/layout,_N_T_/(frontend)/[locale]/page,_N_T_/en"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGZyb250ZW5kKQ/$d$locale/__PAGE__",
    "/!KGZyb250ZW5kKQ/$d$locale",
    "/!KGZyb250ZW5kKQ",
    "/_index",
    "/_head"
  ]
}